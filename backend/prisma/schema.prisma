generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Proveedor {
  id              String   @id @default(uuid())
  razonSocial     String
  cuit            String   @unique
  direccion       String?
  telefono        String?
  email           String?
  contacto        String?
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  recepciones             Recepcion[]
  productos               ProductoInventario[]
  solicitudesComoSugerido SolicitudCompra[]    @relation("ProveedorSugerido")

  @@map("proveedores")
}

model MedicamentoGenerico {
  id                  String   @id @default(uuid())
  nombre              String
  principioActivo     String
  dosis               String?
  formaFarmaceutica   String?
  nombreNormalizado   String   @unique
  activo              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  productos           ProductoInventario[]

  @@map("medicamentos_genericos")
}

model ProductoInventario {
  id              String   @id @default(uuid())
  nombre          String
  descripcion     String?
  principioActivo String?
  presentacion    String?
  categoria       String
  ean             String?  @unique
  troquel         String?  @unique
  stockActual     Int      @default(0)
  stockMinimo     Int      @default(10)
  stockCritico    Int      @default(5)
  unidad          String   @default("unidad")
  proveedorId     String?
  genericoId      String?
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  proveedor       Proveedor?       @relation(fields: [proveedorId], references: [id])
  generico        MedicamentoGenerico? @relation(fields: [genericoId], references: [id])
  lotes           Lote[]
  movimientos     MovimientoStock[]
  recepcionItems  RecepcionDetalle[]
  solicitudItems  SolicitudCompraDetalle[]

  @@map("productos_inventario")
}

model Deposito {
  id          String   @id @default(uuid())
  nombre      String
  tipo        String   @default("PISO")   // CENTRAL | PISO
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lotes               Lote[]
  movimientosOrigen   MovimientoStock[] @relation("MovimientoDepositoOrigen")
  movimientosDestino  MovimientoStock[] @relation("MovimientoDepositoDestino")

  @@map("depositos")
}

model Lote {
  id                  String   @id @default(uuid())
  numeroLote          String
  productoId          String
  depositoId          String
  fechaVencimiento    DateTime
  stockDisponible     Int      @default(0)
  stockInicial        Int      @default(0)
  estado              String   @default("VIGENTE")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  producto            ProductoInventario @relation(fields: [productoId], references: [id])
  deposito            Deposito           @relation(fields: [depositoId], references: [id])
  movimientos         MovimientoStock[]

  @@unique([productoId, numeroLote, depositoId])
  @@map("lotes")
}

model MovimientoStock {
  id                 String   @id @default(uuid())
  productoId         String
  loteId             String?
  depositoId         String?
  depositoDestinoId  String?
  tipo               String
  cantidad           Int
  motivo             String
  referencia         String?
  usuarioId          String?
  createdAt          DateTime @default(now())

  producto         ProductoInventario @relation(fields: [productoId], references: [id])
  lote             Lote?              @relation(fields: [loteId], references: [id])
  deposito         Deposito?          @relation("MovimientoDepositoOrigen", fields: [depositoId], references: [id])
  depositoDestino  Deposito?          @relation("MovimientoDepositoDestino", fields: [depositoDestinoId], references: [id])

  @@map("movimientos_stock")
}

model Recepcion {
  id              String   @id @default(uuid())
  proveedorId     String
  solicitudCompraId String? @unique
  remito          String?
  fechaRecepcion  DateTime
  estado          String   @default("PROCESADA")
  observaciones   String?
  usuarioId       String?
  totalItems      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  proveedor       Proveedor          @relation(fields: [proveedorId], references: [id])
  solicitudCompra SolicitudCompra?   @relation(fields: [solicitudCompraId], references: [id])
  detalles        RecepcionDetalle[]

  @@map("recepciones")
}

model RecepcionDetalle {
  id                  String   @id @default(uuid())
  recepcionId         String
  productoId          String
  cantidad            Int
  ean                 String?
  troquel             String?
  lote                String?
  fechaVencimiento    DateTime?
  createdAt           DateTime @default(now())

  recepcion           Recepcion          @relation(fields: [recepcionId], references: [id], onDelete: Cascade)
  producto            ProductoInventario @relation(fields: [productoId], references: [id])

  @@map("recepcion_detalles")
}

model SolicitudCompra {
  id                         String    @id @default(uuid())
  estado                     String    @default("PENDIENTE")
  prioridad                  String    @default("NORMAL")
  motivo                     String?
  usuarioId                  String?
  ordenCompraId              String?   @unique
  ordenCompraExternaId       String?
  referenciaExterna          String?
  proveedorSugeridoId        String?
  proveedorAdjudicadoRazonSocial String?
  fechaAprobacion            DateTime?
  fechaEntregaEstimada       DateTime?
  observaciones              String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  detalles                   SolicitudCompraDetalle[]
  recepcion                  Recepcion?
  proveedorSugerido          Proveedor? @relation("ProveedorSugerido", fields: [proveedorSugeridoId], references: [id])

  @@map("solicitudes_compra")
}

model SolicitudCompraDetalle {
  id                  String   @id @default(uuid())
  solicitudId         String
  productoId          String
  cantidadSolicitada  Int
  cantidadAprobada    Int?
  unidad              String   @default("unidad")
  precioUnitario      Float?
  createdAt           DateTime @default(now())

  solicitud           SolicitudCompra    @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  producto            ProductoInventario @relation(fields: [productoId], references: [id])

  @@map("solicitud_compra_detalles")
}

model Usuario {
  id           String   @id @default(uuid())
  nombre       String
  email        String   @unique
  passwordHash String
  cargo        String   @default("Farmacéutico")
  rol          String   @default("FARMACEUTICO")
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("usuarios")
}

model Notificacion {
  id          String   @id @default(uuid())
  tipo        String
  titulo      String
  descripcion String
  leida       Boolean  @default(false)
  referencia  String?
  usuarioId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notificaciones")
}
