# Configuración local — Módulo 3 (Farmacia e Insumos).
# Copiar este archivo a `.env`:   cp .env.example .env

# --- Básico ---
DATABASE_URL="file:./dev.db"
PORT=3001
NODE_ENV=development

# --- Autenticación ---
# mock = login local sin Core (usuarios de prueba, cualquier contraseña). RECOMENDADO para correr local.
# core = valida el JWT real de Core vía JWKS (requiere que Core asigne permisos farmacia:* a los usuarios).
AUTH_MODE=mock

# --- Bus de eventos interno (Kafka / Redpanda) ---
# Lo levanta docker-compose (ver SETUP_LOCAL.md). Si NO vas a usar Docker, poné KAFKA_ENABLED=false
# (la API arranca igual; solo se desactiva el envío de órdenes de compra por eventos).
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092

# --- Integraciones con otros módulos de Health Grid (requieren internet) ---
# Core (Módulo 10) — auth / JWKS / token de servicio para consumir otros módulos
CORE_API_URL=https://api.healthcare.cantero.ar
# Compras / Facturación (Módulo 7) — vía el API Gateway de Core
COMPRAS_URL=https://gw.healthcare.cantero.ar/api/billing/compras
COMPRAS_USE_MOCK=false
# HCE (Módulo 1) — recetas
RECETA_MODE=hce
HCE_API_URL=https://healthgrid-hce-backend.onrender.com/api/v1

# ── Modo 100% offline / autocontenido (sin depender de otros módulos) ──
# Si querés correrlo sin internet o sin los otros módulos arriba, usá en su lugar:
#   COMPRAS_USE_MOCK=true      (usa un fixture interno en vez del Módulo 7 real)
#   RECETA_MODE=mock           (recetas de prueba internas en vez de HCE real)
